Algoritmo while_imprimir
	Escribir "Seńor usuario digite el número al llegar"
	Leer n1
	Escribir "Seńor usuario digite el intervalo de los numeros"
	Leer n2
	Definir i Como Entero
	i<-0
	Escribir "Imprimiendo con ciclo Mientras:"
	Mientras i<=n1 Hacer
		Escribir i
		i<-i+n2
	FinMientras
	
FinAlgoritmo
