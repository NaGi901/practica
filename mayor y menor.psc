Algoritmo sin_titulo
	Escribir "Seńor usuario dijite su primer numero"
	Leer n1
	Escribir "Seńor usuario dijite su segundo numero"
	Leer n2
	Escribir "El primer numero capturado es: ",n1
	Escribir "El segundo numero capturado es: ",n2
	Si n1>n2 Entonces
		Escribir "El ",n1 " es mayor que ",n2
	SiNo
		Escribir "El ",n2 " es mayor que ",n1
	Fin Si
	
FinAlgoritmo
