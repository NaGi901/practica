Algoritmo Sueldo
	Escribir "Seþor trabajador dijite su nombre"
	Leer nombre
	Escribir "Seþor ",nombre " dijite sus horas trabajadas"
	Leer horas
	Escribir "Seþor ",nombre, " usted trabajo ", horas , " horas"
	vh<-7959
