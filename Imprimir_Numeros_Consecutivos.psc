Algoritmo Imprimir_Numeros_Consecutivos
	Escribir "Seńor usuario digite el número al llegar"
	Leer n1
	Escribir "Seńor usuario digite el intervalo de los numeros"
	Leer n2
	Definir i Como Entero
	
	
	Escribir "Imprimiendo con ciclo para:"
	Para i <- 0 Hasta n1 Con Paso n2 Hacer
		Escribir i
	FinPara

FinAlgoritmo
